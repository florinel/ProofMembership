{
  "name": "proofmembership",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "util:clean-start:local": "bash ./scripts/clean-start-local.sh",
    "util:stop-all:local": "bash ./scripts/stop-all-local.sh",
    "util:start:devnet": "bash ./scripts/start-devnet.sh",
    "util:stop:devnet": "bash ./scripts/stop-devnet.sh",
    "util:deploy:devnet": "bash ./scripts/deploy-devnet.sh",
    "util:watch:changelog": "node ./scripts/changelog-watch.mjs",
    "dev:web": "pnpm --filter @proofmembership/web dev",
    "build:web": "pnpm --filter @proofmembership/web build",
    "lint:web": "pnpm --filter @proofmembership/web lint",
    "test:web:unit": "pnpm --filter @proofmembership/web test:unit",
    "test:backend:unit": "cargo test --manifest-path programs/membership_core/Cargo.toml",
    "check": "pnpm lint:web"
  },
  "devDependencies": {
    "@types/node": "22.10.2"
  }
}
